# Local dev Postgres (embedded cluster on port 5433). For production use a
# managed Postgres connection string (Neon / Railway / RDS) with the same driver.
DATABASE_URL=postgresql+asyncpg://postgres@localhost:5433/campos

# JWT secret for signing/verifying API tokens.
# NOTE: auth is migrated off Supabase to our own JWT in Phase 2; until then this
# verifies the existing token. Use a strong random value in production.
SUPABASE_JWT_SECRET=change-me-local-dev-secret

# Our own JWT signing secret (Phase 2 auth). Use a strong random value in prod.
JWT_SECRET=change-me-local-dev-secret
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=30

# App
APP_ENV=development
CORS_ORIGINS=http://localhost:5173,http://localhost:4173

# Email — Gmail SMTP. Create an App Password at
# https://myaccount.google.com/apppasswords (requires 2-Step Verification).
# Leave SMTP_USER / SMTP_PASSWORD blank to disable sending (it just logs instead).
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-gmail@gmail.com
SMTP_PASSWORD=your-16-char-app-password
SMTP_FROM=your-gmail@gmail.com
APP_BASE_URL=http://localhost:8080
