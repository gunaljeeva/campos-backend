# Postgres connection string. For local dev: embedded cluster on port 5433 under backend/.pgdev
DATABASE_URL=postgresql+asyncpg://postgres@localhost:5433/campos

# JWT signing secret. Use a strong random value in production.
JWT_SECRET=change-me-local-dev-secret
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=30

# App
APP_ENV=development
CORS_ORIGINS=http://localhost:5173,http://localhost:4173

# Email — Gmail SMTP. Leave blank to disable sending (logs instead).
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
APP_BASE_URL=http://localhost:8080
